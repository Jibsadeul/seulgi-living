generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum RecipeSource {
  PUBLIC
  USER
}

model Sido {
  id       String    @id @db.VarChar(2)
  name     String    @db.VarChar(50)
  sigungus Sigungu[]

  @@map("sido")
}

model Sigungu {
  id     String @id @db.VarChar(5)
  sidoId String @map("sido_id") @db.VarChar(2)
  name   String @db.VarChar(50)

  sido    Sido     @relation(fields: [sidoId], references: [id])
  members Member[]

  @@map("sigungu")
}

model Member {
  id        String    @id @default(uuid()) @db.Uuid
  kakaoId   String    @map("kakao_id") @db.VarChar(255)
  sigunguId String?   @map("sigungu_id") @db.VarChar(5)
  email     String?   @db.VarChar(255)
  nickname  String?   @db.VarChar(100)
  birthday  DateTime? @db.Date
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  sigungu              Sigungu?              @relation(fields: [sigunguId], references: [id])
  refreshToken         RefreshToken?
  recipes              Recipe[]
  recipeScraps         RecipeScrap[]
  fridgeIngredients    FridgeIngredient[]
  groceryPurchaseItems GroceryPurchaseItem[]
  policyScraps         PolicyScrap[]

  @@map("members")
}

model RefreshToken {
  userId    String   @id @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)

  user Member @relation(fields: [userId], references: [id])

  @@map("refresh_token")
}

model Recipe {
  id             String       @id @default(uuid()) @db.Uuid
  source         RecipeSource
  userId         String?      @map("user_id") @db.Uuid
  publicRecipeId String?      @map("public_recipe_id") @db.VarChar(255)
  name           String       @db.VarChar(255)
  category       String?      @db.VarChar(255)
  method         String?      @db.VarChar(255)
  ingredients    String?
  hashTag        String?      @map("hash_tag") @db.VarChar(255)
  mainImageUrl   String?      @map("main_image_url")
  thumbnailUrl   String?      @map("thumbnail_url")
  calories       Float?
  carbohydrate   Float?
  protein        Float?
  fat            Float?
  sodium         Float?
  sodiumTip      String?      @map("sodium_tip")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          Member?        @relation(fields: [userId], references: [id])
  recipeSteps   RecipeStep[]
  recipeScraps  RecipeScrap[]

  @@map("recipes")
}

model RecipeStep {
  id         String  @id @default(uuid()) @db.Uuid
  recipeId   String  @map("recipe_id") @db.Uuid
  stepNumber Int     @map("step_number")
  content    String
  imageUrl   String? @map("image_url")

  recipe Recipe @relation(fields: [recipeId], references: [id])

  @@map("recipe_steps")
}

model RecipeScrap {
  recipeId  String   @map("recipe_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  folderId  String?  @map("folder_id") @db.Uuid

  recipe Recipe @relation(fields: [recipeId], references: [id])
  user   Member @relation(fields: [userId], references: [id])

  @@id([recipeId, userId])
  @@map("recipe_scraps")
}

model FridgeIngredient {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(255)
  quantity  Int
  unit      String?  @db.VarChar(10)
  category  String?  @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user Member @relation(fields: [userId], references: [id])

  @@map("fridge_ingredients")
}

model GroceryPurchaseItem {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  name         String   @db.VarChar(255)
  quantityText String?  @map("quantity_text") @db.VarChar(50)
  price        Int
  purchasedAt  DateTime @map("purchased_at") @db.Timestamp(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user Member @relation(fields: [userId], references: [id])

  @@map("grocery_purchase_items")
}

model Policy {
  id              String    @id @db.VarChar(50)
  name            String    @db.VarChar(255)
  description     String?
  keywords        String?   @db.VarChar(500)
  largeCategory   String?   @map("large_category") @db.VarChar(100)
  mediumCategory  String?   @map("medium_category") @db.VarChar(100)
  ageMin          Int?      @map("age_min")
  ageMax          Int?      @map("age_max")
  noAgeLimit      Boolean   @default(false) @map("no_age_limit")
  applyStartDate  DateTime? @map("apply_start_date") @db.Date
  applyEndDate    DateTime? @map("apply_end_date") @db.Date
  applyPeriodType String?   @map("apply_period_type") @db.VarChar(20)
  applyPeriodText String?   @map("apply_period_text") @db.VarChar(100)
  applicationUrl  String?   @map("application_url")
  zipCd           String?   @map("zip_cd") @db.VarChar(500)
  viewCount       Int       @default(0) @map("view_count")
  syncedAt        DateTime  @map("synced_at") @db.Timestamptz(6)

  scraps PolicyScrap[]

  @@map("policies")
}

model PolicyScrap {
  id               BigInt   @id @default(autoincrement())
  userId           String   @map("user_id") @db.Uuid
  policyId         String   @map("policy_id") @db.VarChar(50)
  notificationSent Boolean  @default(false) @map("notification_sent")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user   Member @relation(fields: [userId], references: [id])
  policy Policy @relation(fields: [policyId], references: [id])

  @@map("policy_scraps")
}
